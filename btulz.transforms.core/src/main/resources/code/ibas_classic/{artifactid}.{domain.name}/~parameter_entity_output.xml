<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!DOCTYPE ArrayList>
<!-- 业务对象 -->
<ns3:ArrayList xmlns:ns2="http://colorcoding.org/btulz/util"
	xmlns:ns3="http://colorcoding.org/btulz/transformers">
	<!-- 基类类型说明 -->
	<OutputMapping Name="bo.class" Binding="Model" Unmatched="EXCEPTION">
		<OutputItem>
			<Content>BOMasterData</Content>
			<Condition Property="ModelType" Value="MasterData" />
		</OutputItem>
		<OutputItem>
			<Content>BOMasterDataLine</Content>
			<Condition Property="ModelType" Value="MasterDataLine" />
		</OutputItem>
		<OutputItem>
			<Content>BODocument</Content>
			<Condition Property="ModelType" Value="Document" />
		</OutputItem>
		<OutputItem>
			<Content>BODocumentLine</Content>
			<Condition Property="ModelType" Value="DocumentLine" />
		</OutputItem>
		<OutputItem>
			<Content>BOSimple</Content>
			<Condition Property="ModelType" Value="Simple" />
		</OutputItem>
		<OutputItem>
			<Content>BOSimpleLine</Content>
			<Condition Property="ModelType" Value="SimpleLine" />
		</OutputItem>
		<OutputItem>
			<Content>BusinessObject</Content>
			<Condition Property="ModelType" Value="Unspecified" />
		</OutputItem>
	</OutputMapping>
	<!-- 数据类型说明 -->
	<OutputMapping Name="bo.type" Binding="Property" Unmatched="EXCEPTION">
		<OutputItem>
			<Content>${Property.getDeclaredType()}</Content>
			<Condition Property="DeclaredType" Operation="NOT_EQUAL" />
		</OutputItem>
		<OutputItem>
			<Content>String</Content>
			<Condition Property="DataType" Value="Alphanumeric" />
		</OutputItem>
		<OutputItem>
			<Content>String</Content>
			<Condition Property="DataType" Value="Memo" />
		</OutputItem>
		<OutputItem>
			<Content>Long</Content>
			<Condition Property="DataType" Value="Numeric" />
			<Condition Property="DataSubType" Value="Long" />
		</OutputItem>
		<OutputItem>
			<Content>Short</Content>
			<Condition Property="DataType" Value="Numeric" />
			<Condition Property="DataSubType" Value="Short" />
		</OutputItem>
		<OutputItem>
			<Content>Integer</Content>
			<Condition Property="DataType" Value="Numeric" />
		</OutputItem>
		<OutputItem>
			<Content>Short</Content>
			<Condition Property="DataType" Value="Date" />
			<Condition Property="DataSubType" Value="Time" />
		</OutputItem>
		<OutputItem>
			<Content>DateTime</Content>
			<Condition Property="DataType" Value="Date" />
		</OutputItem>
		<OutputItem>
			<Content>BigDecimal</Content>
			<Condition Property="DataType" Value="Decimal" />
		</OutputItem>
		<OutputItem>
			<Content>Byte[]</Content>
			<Condition Property="DataType" Value="Bytes" />
		</OutputItem>
	</OutputMapping>
	<!-- 标记类型说明 -->
	<OutputMapping Name="an.type" Binding="Property" Unmatched="EXCEPTION">
		<OutputItem>
			<Content>DataType.ALPHANUMERIC</Content>
			<Condition Property="DataType" Value="Alphanumeric" />
		</OutputItem>
		<OutputItem>
			<Content>DataType.MEMO</Content>
			<Condition Property="DataType" Value="Memo" />
		</OutputItem>
		<OutputItem>
			<Content>DataType.NUMERIC</Content>
			<Condition Property="DataType" Value="Numeric" />
		</OutputItem>
		<OutputItem>
			<Content>DataType.NUMERIC, editType = EditType.TIME</Content>
			<Condition Property="DataType" Value="Date" />
			<Condition Property="DataSubType" Value="Time" />
		</OutputItem>
		<OutputItem>
			<Content>DataType.DATE</Content>
			<Condition Property="DataType" Value="Date" />
		</OutputItem>
		<OutputItem>
			<Content>DataType.DECIMAL, editType = EditType.PRICE</Content>
			<Condition Property="DataType" Value="Decimal" />
			<Condition Property="DataSubType" Value="Price" />
		</OutputItem>
		<OutputItem>
			<Content>DataType.DECIMAL, editType = EditType.QUANTITY</Content>
			<Condition Property="DataType" Value="Decimal" />
			<Condition Property="DataSubType" Value="Quantity" />
		</OutputItem>
		<OutputItem>
			<Content>DataType.DECIMAL, editType = EditType.SUM</Content>
			<Condition Property="DataType" Value="Decimal" />
			<Condition Property="DataSubType" Value="Sum" />
		</OutputItem>
		<OutputItem>
			<Content>DataType.DECIMAL, editType = EditType.RATE</Content>
			<Condition Property="DataType" Value="Decimal" />
			<Condition Property="DataSubType" Value="Rate" />
		</OutputItem>
		<OutputItem>
			<Content>DataType.DECIMAL, editType = EditType.PERCENTAGE</Content>
			<Condition Property="DataType" Value="Decimal" />
			<Condition Property="DataSubType" Value="Percentage" />
		</OutputItem>
		<OutputItem>
			<Content>DataType.DECIMAL, editType = EditType.MEASUREMENT</Content>
			<Condition Property="DataType" Value="Decimal" />
			<Condition Property="DataSubType" Value="Measurement" />
		</OutputItem>
		<OutputItem>
			<Content>DataType.DECIMAL</Content>
			<Condition Property="DataType" Value="Decimal" />
		</OutputItem>
		<OutputItem>
			<Content>DataType.BYTES</Content>
			<Condition Property="DataType" Value="Bytes" />
		</OutputItem>
	</OutputMapping>
	<!-- 标记键类型说明 -->
	<OutputMapping Name="an.key" Binding="Property" Unmatched="SKIP">
		<OutputItem>
			<Content>, primaryKey = true, uniqueKey = true</Content>
			<Condition Property="PrimaryKey" Value="true" />
			<Condition Property="UniqueKey" Value="true" />
		</OutputItem>
		<OutputItem>
			<Content>, primaryKey = true</Content>
			<Condition Property="PrimaryKey" Value="true" />
		</OutputItem>
		<OutputItem>
			<Content>, uniqueKey = true</Content>
			<Condition Property="UniqueKey" Value="true" />
		</OutputItem>
	</OutputMapping>
</ns3:ArrayList>
